{
    "name": "socialite/app",
    "description": "Social Media Web Application",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "cakephp/authentication": "^3.0",
        "cakephp/cakephp": "^5.0",
        "cboden/ratchet": "^0.4.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "cakephp/plugin-installer": true
        }
    },
    "require-dev": {
        "cakephp/bake": "^3.6",
        "cakephp/migrations": "^5.0"
    }
}
